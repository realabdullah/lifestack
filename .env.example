# Lifestack Custom Exporter Configuration

# Server configurations
PORT=3000
LOG_LEVEL=info

# GitHub Settings
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=ghp_yourPersonalAccessTokenHere

# WakaTime Settings
WAKATIME_USERNAME=your-wakatime-username
# Paste your raw WakaTime API key (the code handles Base64 encoding for the basic auth header)
WAKATIME_API_KEY=waka_yourApiKeyHere

# Spotify Settings (for OAuth2 token refresh & currently playing endpoint)
SPOTIFY_CLIENT_ID=yourSpotifyClientIdHere
SPOTIFY_CLIENT_SECRET=yourSpotifyClientSecretHere
SPOTIFY_REFRESH_TOKEN=yourSpotifyRefreshTokenHere

# Polling intervals in milliseconds (optional, defaults are shown below)
POLL_INTERVAL_GITHUB_MS=300000
POLL_INTERVAL_WAKATIME_MS=300000
POLL_INTERVAL_SPOTIFY_MS=30000
